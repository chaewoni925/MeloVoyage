generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  extensions = [vector]
}

model User {
  id              String           @id @default(uuid())
  email           String           @unique
  password        String?
  nickname        String
  profileImage    String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  onboarding      Onboarding?
  recommendations Recommendation[]
  savedPlaylists  SavedPlaylist[]
  spotifyAccount  SpotifyAccount?

  @@map("users")
}

model SpotifyAccount {
  id            String   @id @default(uuid())
  userId        String   @unique
  spotifyUserId String   @unique
  accessToken   String
  refreshToken  String
  expiresAt     DateTime
  scope         String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("spotify_accounts")
}

model Onboarding {
  id          String   @id @default(uuid())
  userId      String   @unique
  genres      String[]
  artistSeeds String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("onboardings")
}

model Destination {
  id              String           @id @default(uuid())
  googlePlaceId   String           @unique
  name            String
  category        String
  address         String?
  latitude        Float
  longitude       Float
  photoUrl        String?
  moodTags       String[]                      // + 추가 TrackPool.moodTags와 대칭
  profileText    String   @db.Text             // + 추가 LLM이 생성한 설명 저장
  embedding      Unsupported("vector(512)")?    // + 추가 Voyage 임베딩 저장
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  recommendations Recommendation[]

  @@index([category])
  @@map("destinations")
}

// 사용자가 예를 들어 강릉 - 플리 생성을 누른 기록
// 이번 추천 정보만 들어가고 곡은 안 들어감
model Recommendation {
  id            String             @id @default(uuid())
  userId        String
  destinationId String
  matchedTags   String[]
  explanation   String
  createdAt     DateTime           @default(now())
  expiresAt     DateTime
  destination   Destination       @relation(fields: [destinationId], references: [id])
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  tracks        RecommendedTrack[]

  @@index([userId])
  @@index([expiresAt])
  @@map("recommendations")
}
// track은 개별 곡 단위. 이거 여러개가 recommendation 하나에 다 담김. 
model RecommendedTrack {
  id               String         @id @default(uuid())
  recommendationId String
  spotifyTrackId   String
  name             String
  artist           String
  albumImageUrl    String?
  previewUrl       String?
  position         Int
  recommendation   Recommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)

  @@index([recommendationId])
  @@map("recommended_tracks")
}

// 추천에 사용할 모든 곡을 저장하는 곡 db
// 플젝 시작 전에 한 번만 만들어두는 데이터
model TrackPool {
  spotifyTrackId String   @id // Spotify 곡 ID (중복 방지)
  name           String // 곡 이름
  artist         String // 아티스트 이름
  artistId       String?       // re-ranking/중복방지용, 선택
  genre          String
  moodTags       String[]   // Last.fm 태그 등
  profileText    String   // genres+tags 합친 텍스트
  embedding Unsupported("vector(512)")?  // pgvector 코사인 유사도 검색용
  cachedAt       DateTime @default(now())
}
// 사용자가 "저장" 버튼을 누르면 생성됨
model SavedPlaylist {
  id                     String       @id @default(uuid())
  userId                 String
  title                  String
  sourceRecommendationId String?
  spotifyPlaylistId      String?
  spotifyPlaylistUrl     String?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  user                   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  tracks                 SavedTrack[]

  @@index([userId])
  @@map("saved_playlists")
}
// 그 플레이리스트 안의 곡들. 이 곡 여러개가 savedPlaylist 안에 담겨있음
model SavedTrack {
  id              String        @id @default(uuid())
  savedPlaylistId String
  spotifyTrackId  String
  name            String
  artist          String
  albumImageUrl   String?
  previewUrl      String?
  position        Int
  savedPlaylist   SavedPlaylist @relation(fields: [savedPlaylistId], references: [id], onDelete: Cascade)

  @@index([savedPlaylistId])
  @@map("saved_tracks")
}